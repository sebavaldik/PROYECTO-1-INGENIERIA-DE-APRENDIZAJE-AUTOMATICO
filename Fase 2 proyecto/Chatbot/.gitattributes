# Forzar LF en scripts de shell para compatibilidad con Linux/Docker
*.sh text eol=lf

# Archivos de texto normales
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.html text eol=lf

# Binarios — no tocar
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
